var deferredPrompt;
window.addEventListener('beforeinstallprompt',function(e){
  e.preventDefault();deferredPrompt=e;
  document.getElementById('install-banner').classList.remove('hidden');
});
document.getElementById('install-banner').addEventListener('click',function(e){
  if(e.target.classList.contains('install-close'))return;
  if(deferredPrompt){deferredPrompt.prompt();deferredPrompt=null;document.getElementById('install-banner').classList.add('hidden');}
});

if('serviceWorker' in navigator){
  window.addEventListener('load',function(){
    navigator.serviceWorker.register('./sw.js').catch(function(){});
  });
}
window.addEventListener('load',function(){
  setTimeout(function(){
    var s=document.getElementById('splash');
    if(s){s.classList.add('hide');setTimeout(function(){s.style.display='none'},400);}
  },800);
});
</script>
